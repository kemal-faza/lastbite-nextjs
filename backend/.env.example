DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lastbite_dev"
JWT_SECRET="change-me-in-production-use-64-char-random-string"
JWT_REFRESH_SECRET="change-me-too-different-from-jwt-secret"
PORT=4000

# Upload
UPLOAD_PROVIDER=local
UPLOAD_LOCAL_DIR=uploads
UPLOAD_MAX_SIZE=5242880
# S3 (optional, used when UPLOAD_PROVIDER=s3)
# S3_REGION=ap-southeast-1
# S3_BUCKET=lastbite-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_PUBLIC_URL=

# Google Maps (geocoding, map display)
GOOGLE_MAPS_API_KEY=

# Firebase FCM (push notifications)
# Saat diisi dengan project ID asli, push notification akan dikirim via FCM.
# Jika dibiarkan 'test-project', push akan di-mock (log ke console saja).
FIREBASE_PROJECT_ID=test-project
# JSON string dari service account key Firebase. Dapatkan dari:
# Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...",...}'
